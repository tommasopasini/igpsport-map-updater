        "**/tmp/**": true,
        "**/osmosis-0.49.2/**": true
    },
    "search.exclude": {
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/input/**": true,
        "**/download/**": true,
        "**/output/**": true,
        "**/tmp/**": true,
        "**/osmosis-0.49.2/**": true
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true
